# LLM Configuration (OpenAI-compatible via LiteLLM)
# Supports: openai, ollama, gemini, azure, anthropic, and any OpenAI-compatible provider
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-your-api-key-here
LLM_API_BASE=
# For Ollama: LLM_API_BASE=http://localhost:11434, LLM_API_KEY=ollama
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2000

# App Configuration
MAX_FILE_SIZE_MB=5
MAX_JOBS=3
TEMP_DIR=/tmp/ats_optimizer
TEMP_CLEANUP_MINUTES=30
CORS_ORIGINS=http://localhost:8000
